---
import { supabase } from '../lib/supabase';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';

// This is an SSR page
const rawSlug = Astro.params.slug || '';
const path = rawSlug === '' ? '/' : `/${rawSlug}/`;

if (rawSlug && !Astro.url.pathname.endsWith('/')) {
  return Astro.redirect(`${Astro.url.pathname}/`, 301);
}

// Fetch page data from Supabase
const { data: page, error } = await supabase
  .from('kassia_pages')
  .select('id,path,slug,page_type,title,h1,meta_title,meta_description,canonical_url,status,index_status,include_in_sitemap,priority,updated_at')
  .eq('path', path)
  .single();

if (error || !page) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

// 404 for draft pages in production only
if (page.status !== 'published' && import.meta.env.PROD) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

// Fetch secondary data in parallel
const [
  { data: rawSections },
  { data: internalLinks },
  { data: configRows },
  { data: faqs },
  { data: gallery }
] = await Promise.all([
  supabase
    .from('kassia_page_sections')
    .select('id,section_type,heading,content,order_index')
    .eq('page_id', page.id)
    .order('order_index', { ascending: true }),
  supabase
    .from('kassia_internal_links')
    .select('id,source_page_id,target_page_id,anchor_text,target_page:kassia_pages!target_page_id(path,status)')
    .eq('source_page_id', page.id),
  supabase
    .from('kassia_site_config')
    .select('key,value'),
  supabase
    .from('kassia_faqs')
    .select('id,question,answer,order_index')
    .eq('page_id', page.id)
    .order('order_index', { ascending: true }),
  supabase
    .from('kassia_gallery_items')
    .select('id,url,alt_text,order_index')
    .eq('page_id', page.id)
    .order('order_index', { ascending: true })
]);

const sections = rawSections
  ?.map(s => ({ ...s, content: typeof s.content === 'string' ? JSON.parse(s.content) : (s.content || {}) }))
  ?.filter(s => s.content?.is_active !== false);

const publishedLinks = internalLinks
  ? internalLinks.filter(link => link.target_page && link.target_page.status === 'published')
  : [];

// Robots meta
const robots = page.index_status === 'index' ? 'index, follow' : 'noindex, follow';

// Canonical
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://www.kassia.ro';
const canonical = page.canonical_url || `${siteUrl}${path}`;

const config = Object.fromEntries(configRows?.map(row => [row.key, row.value]) || []);
const phone = config.phone;

const validFaqs = faqs?.filter(f => f.question && f.answer && !f.question.startsWith('Draft FAQ') && f.answer !== 'Placeholder') || [];

const validImages = gallery?.filter(g => g.url && g.url.trim() !== '') || [];

// Generate Schema.org
const schemas = [];

// 1. Organization / LocalBusiness
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Kassia",
  "url": siteUrl,
  "logo": `${siteUrl}/logo.png`,
  "image": validImages.length > 0 ? validImages[0].url : undefined
};
if (phone) {
  localBusinessSchema.telephone = phone;
}
if (config && Object.keys(config).length > 0) {
  localBusinessSchema.address = {
    "@type": "PostalAddress",
    "addressRegion": "București & Ilfov",
    "addressCountry": "RO"
  };
}
schemas.push(localBusinessSchema);

// 2. Service Schema
if (['service', 'service_pillar', 'event', 'location', 'satellite'].includes(page.page_type)) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": page.h1 || page.title,
    "provider": {
      "@type": "LocalBusiness",
      "name": "Kassia"
    },
    "areaServed": "Ilfov, București"
  });
}

// 3. FAQPage Schema
if (validFaqs.length > 0) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": validFaqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  });
}

// 4. BreadcrumbList
const pathSegments = path.split('/').filter(Boolean);
if (pathSegments.length > 0) {
  const itemListElement = pathSegments.map((segment, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": segment.replace(/-/g, ' '),
    "item": `${siteUrl}/${pathSegments.slice(0, index + 1).join('/')}/`
  }));

  schemas.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": itemListElement
  });
}

const ogImage = validImages.length > 0 ? validImages[0].url : undefined;
---

<Layout title={page.meta_title} description={page.meta_description} canonical={canonical} robots={robots} schemas={schemas} ogImage={ogImage}>
  <div class="kassia-premium-page">

    {/* HERO SECTION */}
    {(() => {
      const heroSec = sections?.find(s => s.section_type === 'hero');
      const hasBody = heroSec?.content?.body && heroSec.content.body.trim() !== '';
      return (
        <header class={`hero-section ${heroSec?.content?.image_url ? 'has-image' : ''}`}>
          <div class="hero-overlay"></div>
          <div class="container hero-content-wrapper">
            <div class="hero-text-content">
              <h1 class="page-title">{page.h1}</h1>
              {hasBody ? (
                <>
                  <div class="hero-subtitle" set:html={heroSec.content.body} />
                  {heroSec.content?.cta_text && heroSec.content?.cta_url && (
                    <a href={heroSec.content.cta_url} class="btn-primary" style="margin-top:2rem; display:inline-block;">
                      {heroSec.content.cta_text}
                    </a>
                  )}
                </>
              ) : (
                <>
                  {page.meta_description && <p class="hero-subtitle">{page.meta_description}</p>}
                </>
              )}
            </div>
            {heroSec?.content?.image_url && (
              <div class="hero-image-wrapper">
                <img src={heroSec.content.image_url} alt={page.h1} class="hero-image" onerror="this.style.display='none'" loading="eager" />
              </div>
            )}
          </div>
        </header>
      );
    })()}

    {/* SERVICE CARDS GRID */}
    {sections && sections.filter(s => s.section_type === 'service_card').length > 0 && (
      <section class="service-cards-section bg-white">
        <div class="container">
          <h2 class="section-heading text-center">Alege Serviciul Dorit</h2>
          <div class="service-cards-grid">
            {sections.filter(s => s.section_type === 'service_card').map((card) => (
              <a href={card.content?.cta_url || '#'} class="service-card-link">
                <div class="service-card">
                  <div class="service-card-image">
                    {card.content?.image_url && card.content.image_url.trim() !== '' && (
                      <img src={card.content.image_url} alt="" onerror="this.style.display='none'" loading="lazy" />
                    )}
                    <div class="service-card-overlay"></div>
                  </div>
                  <div class="service-card-content">
                    <h3 class="service-card-title">{card.heading}</h3>
                    {card.content?.subheading && <p class="service-card-subtitle">{card.content.subheading}</p>}
                    <span class="service-card-cta">{card.content?.cta_text || 'Vezi Detalii'} &rarr;</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* SECTIONS LOOP */}
    {page.slug === 'preturi-decoratiuni-baloane' ? (
      <>
        {sections && sections.filter(s => s.heading === 'Cum se calculează prețul unui decor cu baloane?').map(section => (
          <section class="content-section bg-light" id="cum-se-calculeaza">
            <div class="container section-grid" style="grid-template-columns: 1fr; max-width: 800px; text-align: center;">
              <div class="section-text">
                <h2 class="section-heading">{section.heading}</h2>
                {section.content?.body && <div class="section-body prose" set:html={section.content.body} />}
              </div>
            </div>
          </section>
        ))}
        <div id="content" class="container" style="padding: 4rem 1rem;">
          <div class="pricing-details-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem;">
            {sections && sections.filter(s => !['hero', 'gallery', 'faq', 'service_card'].includes(s.section_type) && s.heading !== 'Cum se calculează prețul unui decor cu baloane?').map((section) => (
              <div class="pricing-detail-card" id={section.heading ? 'preturi-' + section.heading.replace('Prețuri ', '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') : undefined} style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #e2e8f0; display: flex; flex-direction: column;">
                <h3 class="pricing-card-title" style="font-size: 1.5rem; margin-bottom: 1rem; color: var(--primary-dark);">{section.heading}</h3>
                {section.content?.body && <div class="pricing-card-body prose" set:html={section.content.body} style="flex-grow: 1; margin-bottom: 1.5rem;" />}
                {section.content?.cta_url && section.content?.cta_text && (
                  <a href={section.content.cta_url} class="btn-primary" style="align-self: flex-start; margin-top: auto;">{section.content.cta_text}</a>
                )}
              </div>
            ))}
          </div>
        </div>
      </>
    ) : (
      <div id="content" class="sections-wrapper">
        {sections && sections.filter(s => !['hero', 'gallery', 'faq', 'service_card'].includes(s.section_type)).map((section, index) => (
          <section
            id={section.heading ? 'preturi-' + section.heading.replace('Prețuri ', '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') : undefined}
            class={`content-section ${index % 2 === 0 ? 'bg-light' : 'bg-white'}`}
          >
            <div class="container section-grid">
              <div class="section-text">
                {section.heading && <h2 class="section-heading">{section.heading}</h2>}
                {section.content?.subheading && <h3 class="section-subheading">{section.content.subheading}</h3>}
                {section.content?.body && <div class="section-body" set:html={section.content.body} />}
                {section.content?.cta_text && section.content?.cta_url && (
                  <a href={section.content.cta_url} class="btn-primary">{section.content.cta_text}</a>
                )}
              </div>
              {/* Image render */}
              {section.content?.image_url && section.content.image_url.trim() !== '' && (
                <div class="section-image-placeholder">
                  <img src={section.content.image_url} alt="" onerror="this.parentElement.style.display='none'" loading="lazy" />
                </div>
              )}
            </div>
          </section>
        ))}
      </div>
    )}

    {/* GALLERY SECTION */}
    {sections && sections.some(s => s.section_type === 'gallery') && gallery && gallery.some(img => img.url && img.url.trim() !== '') && (
      <section class="gallery-section bg-light">
        <div class="container">
          <h2 class="section-heading text-center">Galerie Foto</h2>
          <div class="gallery-grid">
            {gallery.filter(img => img.url && img.url.trim() !== '').map(img => (
              <figure class="gallery-item">
                <img src={img.url} alt={img.alt_text || 'Galerie'} loading="lazy" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* FAQ SECTION */}
    {validFaqs.length > 0 && (
      <section class="faq-section bg-white">
        <div class="container">
          <h2 class="section-heading text-center">Întrebări Frecvente</h2>
          <div class="faq-accordion">
            {validFaqs.map(faq => (
              <details class="faq-details">
                <summary class="faq-summary">{faq.question}</summary>
                <div class="faq-answer">{faq.answer}</div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <ReviewsCarousel />
    <Footer internalLinks={publishedLinks} />

  </div>
</Layout>

<style>
  /* GLOBAL TOKENS & RESETS */
  :root {
    --primary: #a855f7;
    --primary-dark: #9333ea;
    --accent: #ec4899;
    --text-main: #1e293b;
    --text-muted: #475569;
    --bg-light: #f8fafc;
    --bg-white: #ffffff;
    --radius: 16px;
  }

  .kassia-premium-page {
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--text-main);
    line-height: 1.6;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .bg-light { background-color: var(--bg-light); }
  .bg-white { background-color: var(--bg-white); }
  .text-center { text-align: center; }

  /* HERO SECTION */
  .hero-section {
    position: relative;
    padding: 8rem 0 6rem;
    background: linear-gradient(135deg, rgba(168,85,247,0.1) 0%, rgba(236,72,153,0.1) 100%);
    text-align: center;
    overflow: hidden;
  }
  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: white;
    color: var(--primary);
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(168,85,247,0.1);
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: linear-gradient(to right, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 3rem;
  }
  .hero-scroll-btn {
    display: inline-block;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    transition: color 0.3s;
  }
  .hero-scroll-btn:hover { color: var(--primary); }

  .hero-content-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-section:not(.has-image) .hero-content-wrapper {
    display: block;
  }
  .hero-section.has-image {
    text-align: center;
  }
  .hero-image {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.15);
  }
  @media (min-width: 992px) {
    .hero-section.has-image .hero-content-wrapper {
      grid-template-columns: 1.1fr 1fr;
      text-align: left;
    }
    .hero-section.has-image .hero-subtitle {
      margin-left: 0;
      margin-right: 0;
    }
  }

  /* CONTENT SECTIONS */
  .content-section {
    padding: 6rem 0;
  }
  .section-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .section-grid { grid-template-columns: 1fr 1fr; }
    /* Alternate image position */
    .content-section:nth-child(even) .section-text { order: 2; }
    .content-section:nth-child(even) .section-image-placeholder { order: 1; }
  }
  .section-heading {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--text-main);
  }
  .section-subheading {
    font-size: 1.25rem;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .section-body {
    color: var(--text-muted);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }
  .section-body p { margin-bottom: 1rem; }

  .section-image-placeholder img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  /* BUTTONS */
  .btn-primary {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: linear-gradient(to right, var(--primary), var(--accent));
    color: white;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1.125rem;
    transition: transform 0.3s, box-shadow 0.3s;
    box-shadow: 0 10px 15px -3px rgba(168,85,247,0.3);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 25px -5px rgba(168,85,247,0.4);
  }

  /* GALLERY SECTION */
  .gallery-section { padding: 6rem 0; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }
  .gallery-item {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    aspect-ratio: 1/1;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .gallery-item:hover img { transform: scale(1.05); }

  /* FAQ SECTION */
  .faq-section {
    padding: 5rem 0;
  }
  .faq-accordion {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-details {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .faq-summary {
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    color: var(--text-main);
    list-style: none;
    position: relative;
    padding-right: 2rem;
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: var(--primary);
    transition: transform 0.2s;
  }
  .faq-details[open] .faq-summary::after {
    transform: translateY(-50%) rotate(45deg);
  }
  .faq-answer {
    margin-top: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* SERVICE CARDS GRID */
  .service-cards-section {
    padding: 5rem 0;
  }
  .service-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  .service-card-link {
    text-decoration: none;
    display: block;
  }
  .service-card {
    border-radius: 20px;
    overflow: hidden;
    background: white;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -10px rgba(168, 85, 247, 0.2);
  }
  .service-card-image {
    position: relative;
    width: 100%;
    padding-top: 100%; /* 1:1 Aspect Ratio (Square) */
    overflow: hidden;
  }
  .service-card-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .service-card:hover .service-card-image img {
    transform: scale(1.05);
  }
  .service-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, transparent 50%);
  }
  .service-card-content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .service-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }
  .service-card-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }
  .service-card-cta {
    font-weight: 600;
    color: var(--primary);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .service-card:hover .service-card-cta {
    color: var(--primary-dark);
  }

  @media (max-width: 767px) {
    .section-grid {
      grid-template-columns: 1fr;
    }
    .content-section:nth-child(even) .section-image-placeholder {
      order: 2;
    }
    .hero-section {
      padding: 6rem 0 4rem;
    }
    .page-title {
      font-size: 2.5rem;
    }
    .service-cards-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* RELATED LINKS */
  .related-links-section { padding: 4rem 0; }
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .related-link-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background: white;
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text-main);
    font-weight: 600;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    transition: all 0.2s;
  }
  .related-link-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    transform: translateY(-2px);
    color: var(--primary);
  }
  .related-link-card .arrow { color: var(--accent); font-weight: bold; }
</style>
