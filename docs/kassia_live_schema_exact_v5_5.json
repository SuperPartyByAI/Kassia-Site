{
  "kassia_pages": {
    "required": [
      "id",
      "slug",
      "path",
      "page_type",
      "status",
      "index_status",
      "include_in_sitemap",
      "title",
      "h1",
      "meta_title",
      "meta_description",
      "priority"
    ],
    "columns": {
      "id": {
        "type": "string",
        "format": "uuid",
        "default": "gen_random_uuid()"
      },
      "slug": {
        "type": "string",
