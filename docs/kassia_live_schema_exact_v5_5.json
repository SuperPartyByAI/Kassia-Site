      },
      "parent_page_id": {
        "type": "string",
        "format": "uuid"
      },
      "service_type": {
        "type": "string",
        "format": "character varying"
      },
      "event_type": {
        "type": "string",
        "format": "character varying"
      },
      "location_type": {
        "type": "string",
        "format": "character varying"
      },
      "city": {
        "type": "string",
        "format": "character varying"
      },
      "sector": {
        "type": "string",
        "format": "character varying"
      },
      "neighborhood": {
        "type": "string",
        "format": "character varying"
      },
      "priority": {
        "type": "number",
        "format": "numeric",
        "default": 0.5
      },
      "created_at": {
        "type": "string",
        "format": "timestamp with time zone",
        "default": "now()"
