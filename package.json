{
  "name": "zoukasplay-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:with-seo-validate": "node scripts/seo-validate.mjs && astro build",
    "build:skip-check": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "seo:validate": "node scripts/seo-validate.mjs",
    "seo:report": "node scripts/seo-report.mjs",
    "seo:create": "node scripts/seo-create.mjs",
    "seo:keyword-map": "node scripts/seo-keyword-map-audit.mjs",
    "seo:crawl": "node scripts/seo-crawl.mjs",
    "seo:sitemap:audit": "node scripts/seo-sitemap-audit.mjs",
    "seo:test:sitemap": "node scripts/seo-test-sitemap.mjs",
    "seo:interlinking": "node scripts/seo-interlinking.mjs",
    "seo:audit": "node scripts/seo-full-audit.mjs",
    "seo:test:rpc": "node scripts/seo-test-rpc.mjs",
    "seo:test:server": "node scripts/seo-test-with-server.mjs",
    "seo:test:cannibal": "node scripts/seo-test-cannibalization.mjs",
    "seo:test:keyword-map": "node scripts/seo-keyword-map-audit.mjs",
    "seo:test:cleanup": "node scripts/seo-test-cleanup-check.mjs",
    "seo:test:local-graph": "node scripts/seo-test-local-graph.mjs",
    "seo:test:site-provisioning": "SEO_TEST_MODE=true node scripts/seo-test-site-provisioning.mjs",
    "seo:test:public-runtime": "SEO_TEST_MODE=true node scripts/seo-test-public-tenant-runtime.mjs",
    "seo:test:guard": "node scripts/seo-test-guard-check.mjs",
    "seo:test:marketplace-browse": "node scripts/seo-test-marketplace-browse.mjs",
    "seo:test:marketplace-supplier-listings": "node scripts/seo-test-marketplace-supplier-listings.mjs",
    "seo:test:supplier-profiles": "node scripts/seo-test-supplier-profiles.mjs",
    "seo:test:chat-anti-circumvention": "node scripts/seo-test-chat-anti-circumvention.mjs",
    "seo:test": "npm run seo:test:guard && npm run seo:test:site-provisioning && npm run seo:test:public-url-utils && npm run seo:test:public-runtime && npm run seo:test:no-test-rpc && npm run seo:test:rpc && npm run seo:test:cannibal && npm run seo:test:keyword-map && npm run seo:test:server && npm run seo:test:taxonomy && npm run seo:test:offering-scope && npm run seo:test:page-generation && npm run seo:test:zouka-offerings && npm run seo:test:location-graph && npm run seo:test:service-location-targets && npm run seo:test:local-links && npm run seo:test:publish-gate-local && npm run seo:test:cross-site-local && npm run seo:test:operator-scope && npm run seo:test:operator-queue && npm run seo:test:operator-missing && npm run seo:test:editorial-work-queue && npm run seo:test:editorial-content-save && npm run seo:test:editorial-content-partial && npm run seo:test:editorial-validate && npm run seo:test:editorial-review-gate && npm run seo:test:editorial-publish-strict && npm run seo:test:editorial-cross-site && npm run seo:test:editorial-events && npm run seo:test:marketplace-browse && npm run seo:test:marketplace-supplier-listings && npm run seo:test:supplier-profiles && npm run seo:test:chat-anti-circumvention && npm run seo:test:cleanup",
    "deploy:production": "PUBLIC_SITE_ENV=production npm run env:validate:production && PUBLIC_SITE_ENV=production npm run build && npm run seo:test:no-test-rpc:production && bash scripts/deploy-production.sh",
    "smoke:production": "npx tsx scripts/smoke-production.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload zoukasplay-site --update-env",
    "pm2:logs": "pm2 logs zoukasplay-site",
    "seo:test:admin-site-scope": "node scripts/seo-test-admin-site-scope.mjs",
    "seo:test:site-isolation": "node scripts/seo-test-site-isolation.mjs",
    "seo:test:site-required": "node scripts/seo-test-site-required.mjs",
    "seo:test:taxonomy": "node scripts/seo-test-service-taxonomy.mjs",
    "seo:test:offering-scope": "node scripts/seo-test-offering-site-scope.mjs",
    "seo:test:page-generation": "node scripts/seo-test-page-generation.mjs",
    "seo:test:zouka-offerings": "node scripts/seo-test-zouka-offerings.mjs",
    "seo:test:location-graph": "node scripts/seo-test-location-graph.mjs",
    "seo:test:service-location-targets": "node scripts/seo-test-service-location-targets.mjs",
    "seo:test:target-draft-generation": "node scripts/seo-test-target-draft-generation.mjs",
    "seo:test:local-links": "npx tsx scripts/seo-test-local-links.mjs",
    "seo:test:publish-gate-local": "node scripts/seo-test-publish-gate-local.mjs",
    "seo:test:cross-site-local": "node scripts/seo-test-cross-site-local.mjs",
    "seo:test:operator-scope": "node scripts/seo-test-operator-dashboard-scope.mjs",
    "seo:test:operator-queue": "node scripts/seo-test-operator-work-queue.mjs",
    "seo:test:operator-missing": "node scripts/seo-test-missing-marketplace-services.mjs",
    "seo:test:editorial-work-queue": "node scripts/seo-test-editorial-work-queue.mjs",
    "seo:test:editorial-content-save": "node scripts/seo-test-editorial-content-save.mjs",
    "seo:test:editorial-content-partial": "node scripts/seo-test-editorial-content-partial.mjs",
    "seo:test:editorial-validate": "node scripts/seo-test-editorial-validate.mjs",
    "seo:test:editorial-review-gate": "node scripts/seo-test-editorial-review-gate.mjs",
    "seo:test:editorial-publish-strict": "node scripts/seo-test-editorial-publish-strict.mjs",
    "seo:test:editorial-cross-site": "node scripts/seo-test-editorial-cross-site.mjs",
    "seo:test:editorial-events": "node scripts/seo-test-editorial-events.mjs",
    "seo:test:no-test-rpc": "node scripts/seo-test-no-test-rpc-in-prod.mjs",
    "seo:test:no-test-rpc:production": "PUBLIC_SITE_ENV=production node scripts/seo-test-no-test-rpc-in-prod.mjs --production",
    "seo:test:public-url-utils": "npx tsx scripts/seo-test-public-url-utils.mjs",
    "env:validate:production": "PUBLIC_SITE_ENV=production node scripts/validate-production-env.mjs --production"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "cheerio": "^1.2.0",
    "cookie": "^1.1.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "puppeteer": "^24.43.1"
  }
}
